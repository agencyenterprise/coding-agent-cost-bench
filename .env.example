# Copy to .env and fill in. Credentials only — do NOT commit real keys.
# Plain KEY=value (no quotes, no `export`) so `docker run --env-file .env` works directly.
# .env is gitignored AND dockerignored — it is never committed and never baked into the image.

# Proxy token (wk-… / ws-…) — authenticates inference requests TO the GLM endpoint.
# Create: `modal workspace proxy-tokens create` (or run the bench once; setup prints a pair if none exists).
MODAL_ENDPOINT=
MODAL_KEY=
MODAL_SECRET=

# Account token (ak-… / as-…) — controls your Modal account: provisions the endpoint.
# Create: modal.com/settings/tokens → New token, or `modal token new` then copy from ~/.modal.toml.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Frontier providers (Claude Code / opencode read these)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# sync-and-report.sh — pull benchmark results from the AWS box (SSH)
REMOTE=
REMOTE_RESULTS=results
