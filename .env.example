# Copy to .env and `source .env` before running the benchmark.
# Do NOT commit real keys.

# --- Modal (self-hosted GLM-5.2 endpoint) ---
export MODAL_KEY=
export MODAL_SECRET=
export MODAL_ENDPOINT="https://ae-alignment--ep-modal-auto-endpoints-server.us-west.modal.direct/v1"

# --- Frontier providers (opencode built-ins) ---
export ANTHROPIC_API_KEY=
export OPENAI_API_KEY=
export GEMINI_API_KEY=

# --- aggregate.py: route these models' $ to Modal GPU billing, not per-token ---
export GLM_MODELS="modal,GLM"
# Optional fallback if modal_costs.csv is missing a row: $ = duration_s * rate.
# Prefer filling modal_costs.csv from the Modal dashboard instead.
export MODAL_RATE_PER_SEC=0
