# Copy to .env and `source .env` before running. Credentials only — do NOT commit real keys.

# Modal (self-hosted GLM-5.2 endpoint)
export MODAL_ENDPOINT="https://ae-alignment--ep-modal-auto-endpoints-server.us-west.modal.direct/v1"
export MODAL_KEY=
export MODAL_SECRET=

# Modal account-level auth (`modal setup` equivalent, non-interactive) — needed by
# setup_auto_endpoint.sh and grade_swe.sh's `modal` CLI calls. Different from MODAL_KEY/
# MODAL_SECRET above (that pair is the AEP's own proxy token, not account auth).
export MODAL_TOKEN_ID=
export MODAL_TOKEN_SECRET=

# Frontier providers (opencode auto-detects these)
export ANTHROPIC_API_KEY=
export OPENAI_API_KEY=
export GEMINI_API_KEY=

# Hugging Face token — only for the App path (run_app.sh / modal_app.py) to pull the ~700 GB GLM
# weights authenticated (unauthenticated is rate-limited / 401s on gated repos). Not needed for AEP.
export HF_TOKEN=
